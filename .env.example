# Copy to .env (or .env.local) and fill in. Both are gitignored via `.env*`.

# REQUIRED for Stage 3 (image generation). Server-side only — never exposed to the browser.
# Uses OpenAI image billing, which is separate from a ChatGPT subscription.
OPENAI_API_KEY=

# Image model. Default gpt-image-2 (released 2026-04-21). Alternatives: gpt-image-1.5,
# gpt-image-1, gpt-image-1-mini (cheaper/older).
GIL_IMAGE_MODEL=gpt-image-2
GIL_IMAGE_SIZE=1536x1024
GIL_IMAGE_QUALITY=low

# --- Cost controls (the money guardrails). Tune for your budget. ---
# Estimated IDR per image. PLACEHOLDER — validate against real OpenAI pricing.
GIL_IMAGE_COST_IDR=1500
# Max images per project (e.g. 2 views x 3 regen).
GIL_MAX_IMAGES_PER_PROJECT=6
# Max regenerations per view type (front elevation / 3D).
GIL_MAX_REGEN_PER_VIEW=3
# Hard daily spend ceiling across ALL projects. The backstop against abuse.
GIL_DAILY_SPEND_CAP_IDR=100000
